datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  PARTICIPANTE
  ORGANIZADOR
}

enum EnrollmentStatus {
  ATIVA
  CANCELADA
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  role         UserRole     @default(PARTICIPANTE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  activities   Activity[]   @relation("UserActivities")
  enrollments  Enrollment[]

  @@map("users")
}

model Activity {
  id          String       @id @default(uuid())
  title       String
  description String
  location    String
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int
  createdById String
  creator     User         @relation("UserActivities", fields: [createdById], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("activities")
}

model Enrollment {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ATIVA)
  createdAt  DateTime         @default(now())

  @@unique([userId, activityId])
  @@map("enrollments")
}
